# Server
PORT=5000
NODE_ENV=development
ORIGIN_URI=*

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/agricare

# JWT
JWT_SECRET=your_jwt_secret_here

# Email (Nodemailer)
# For Gmail: use an App Password (recommended) instead of your normal password.
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
# Optional
EMAIL_FROM=AgriCare <your_email@gmail.com>

# SMTP (optional overrides; if SMTP_HOST not set, service auth is used)
# SMTP_SERVICE=gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Public URL used inside emails (recommended in production)
# Example: https://api.yourdomain.com
PUBLIC_BACKEND_URL=http://localhost:5000

# Gemini (required for AI chat, advisory, garden tips, crop insights)
GEMINI_API_KEY=your_gemini_api_key_here

# Other services
ML_SERVICE_URL=http://localhost:5001
